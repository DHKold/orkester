# Dev / demo image for Orkester
#
# Builds the release binary + plugins, then packages them together with the
# default workaholic config into a Debian-based image that has:
#   • a shell (bash)          — for exec / debugging
#   • the Docker CLI          — so the container executor can reach the host socket
#   • the example configs     — pre-loaded at /orkester/bin/configs/
#
# This image is intended to be deployed with the Helm chart for quick demos and
# integration testing.  It is NOT hardened for production use.
#
# Build (from project root):
#   podman build -t orkester:dev -f Dockerfile.dev .
#
# Run locally:
#   podman run --rm -p 8080:8080 \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     orkester:dev

# ── Stage 1: build ────────────────────────────────────────────────────────────
# Pin to Bookworm so the glibc version matches the runtime stage.
FROM rust:1-slim-bookworm AS builder
WORKDIR /build

COPY rust/ .

# ── orkester workspace: host binary + plugins ────────
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/build/orkester/target \
    cd /build/orkester \
 && cargo build --release \
        -p orkester-host \
        -p orkester-plugin-sample \
        -p orkester-plugin-metrics \
        -p orkester-plugin-logging \
 && cp target/release/orkester                         /usr/local/bin/orkester \
 && cp target/release/liborkester_plugin_sample.so     /tmp/ \
 && cp target/release/liborkester_plugin_metrics.so    /tmp/ \
 && cp target/release/liborkester_plugin_logging.so    /tmp/

# ── workaholic workspace: workaholic plugin ────────────────────────────────────
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/build/workaholic/target \
    cd /build/workaholic \
 && cargo build --release -p orkester-plugin-workaholic \
 && cp target/release/liborkester_plugin_workaholic.so /tmp/

# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM debian:bookworm-slim

# Install runtime dependencies:
#   • ca-certificates — TLS to the Kubernetes API and external services
#   • Docker CE CLI   — lets the container executor talk to the host socket
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates curl gnupg \
 && install -m 0755 -d /etc/apt/keyrings \
 && curl -fsSL https://download.docker.com/linux/debian/gpg \
      -o /etc/apt/keyrings/docker.asc \
 && chmod a+r /etc/apt/keyrings/docker.asc \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
      https://download.docker.com/linux/debian \
      $(. /etc/os-release && echo \"$VERSION_CODENAME\") stable" \
      > /etc/apt/sources.list.d/docker.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends docker-ce-cli \
 && rm -rf /var/lib/apt/lists/*

# Orkester binary
COPY --from=builder /usr/local/bin/orkester /usr/local/bin/orkester

# Plugins directory (matches Helm chart config: /orkester/plugins/)
RUN mkdir -p /orkester/plugins /orkester/samples /orkester/catalog \
 && chmod 755 /orkester/plugins /orkester/samples /orkester/catalog
COPY --from=builder /tmp/liborkester_plugin_sample.so     /orkester/plugins/
COPY --from=builder /tmp/liborkester_plugin_metrics.so    /orkester/plugins/
COPY --from=builder /tmp/liborkester_plugin_logging.so    /orkester/plugins/
COPY --from=builder /tmp/liborkester_plugin_workaholic.so /orkester/plugins/

# Copy example configs and UI assets.
COPY bin/configs/        /orkester/catalog/
COPY bin/workaholic.yaml /orkester/samples/workaholic.yaml
COPY ui/ /orkester/ui/

# Writable data directory expected by the default config.
# Create the orkester user (UID 10001) that matches the pod security context,
# then chown all writable paths so the process can create subdirectories.
RUN groupadd --gid 10001 orkester \
 && useradd  --uid 10001 --gid 10001 --no-create-home --shell /sbin/nologin orkester \
 && mkdir -p /orkester/data /orkester/logs \
 && chown -R 10001:10001 /orkester/data /orkester/logs

USER orkester

RUN mkdir -p /orkester/data /orkester/logs \
 && chmod 700 /orkester/data /orkester/logs

WORKDIR /orkester
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/orkester"]
